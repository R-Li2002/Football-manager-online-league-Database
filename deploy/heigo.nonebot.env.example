HEIGO_PORT_BIND=127.0.0.1:8080:8080
SESSION_COOKIE_SECURE=auto

# 仅首次初始化管理员时临时填写，完成后删除
HEIGO_BOOTSTRAP_ADMINS=

# 主站内部分享与 PNG 签名密钥，必须填写
INTERNAL_SHARE_TOKEN=change-this-internal-share-token
INTERNAL_RENDER_SIGNING_KEY=change-this-render-signing-key
HEIGO_SHARE_TEMPLATE_VERSION=2

# NapCat / NoneBot2 配置
ONEBOT_ACCESS_TOKEN=change-this-onebot-access-token
QQ_BOT_ALLOWED_GROUPS=
QQ_BOT_ALLOW_ALL_GROUPS=false

# Docker 内网地址，保持默认即可
HEIGO_BASE_URL=http://heigo:8080
HEIGO_RENDER_BASE_URL=http://heigo:8080
HEIGO_RENDER_TTL_SECONDS=90
BOT_DEFAULT_THEME=dark
BOT_ROSTER_PAGE_SIZE=16
BOT_USER_COOLDOWN_SECONDS=5
BOT_GROUP_LIMIT_PER_MINUTE=20

# NapCat WebUI 只绑定本机
NAPCAT_WEBUI_BIND=127.0.0.1:6099:6099

# 生产域名不会进入容器内部通信；请把 deploy/nginx/heigo.example.conf 里的 example.com 替换成你的真实域名
